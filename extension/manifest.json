{
  "manifest_version": 3,
  "name": "ShieldAI Prompt Injection Analysis",
  "version": "1.0",
  "description": "Analyze LLM prompts dynamically for prompt injection vectors using Signature, Heuristic, and ML techniques.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
